---
import TextSlider from "../components/TextSlider.astro";
import Separator from "../components/Separator.astro";
import siteLogo from "../../logo (1080 x 1080 px) (2).png";
---

<header>
  <h1>
    <a href="https://acts.megamaalai.org" target="_blank" rel="noopener noreferrer"
      ><img class="site-logo" src={siteLogo.src} alt="Meet the Acts" /></a
    >
  </h1>
  <nav aria-label="Primary">
    <ul>
      <li>
        <a href="https://home.megamaalai.org" target="_blank" rel="noopener noreferrer"
          ><TextSlider content="Home" /></a
        >
      </li>
      <li>
        <a href="https://timeline.megamaalai.org" target="_blank" rel="noopener noreferrer"
          ><TextSlider content="Timeline" /></a
        >
      </li>
      <li>
        <a href="https://acts.megamaalai.org" target="_blank" rel="noopener noreferrer"
          ><TextSlider content="Acts" /></a
        >
      </li>
      <li>
        <a href="https://tickets.megamaalai.org" target="_blank" rel="noopener noreferrer"
          ><TextSlider content="Tickets" /></a
        >
      </li>
      <li>
        <a
          href="https://www.instagram.com/megamaalai/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Contact or Sponsor on Instagram"
        >
          <TextSlider
            ><span class="contact-label" data-contact-sponsor-label>Contact</span></TextSlider
          >
        </a>
      </li>
    </ul>
  </nav>
</header>
<Separator />

<script is:inline>
  const setupContactSponsorToggle = () => {
    const label = document.querySelector("[data-contact-sponsor-label]");
    if (!label) return;

    const labels = ["Contact", "Sponsor"];
    let index = 0;

    if (window.__contactSponsorIntervalId) {
      window.clearInterval(window.__contactSponsorIntervalId);
    }

    window.__contactSponsorIntervalId = window.setInterval(() => {
      label.classList.add("is-fading");

      window.setTimeout(() => {
        index = (index + 1) % labels.length;
        label.textContent = labels[index];
        label.classList.remove("is-fading");
      }, 220);
    }, 5000);
  };

  document.addEventListener("astro:page-load", setupContactSponsorToggle);

  document.addEventListener("astro:before-swap", () => {
    if (window.__contactSponsorIntervalId) {
      window.clearInterval(window.__contactSponsorIntervalId);
      window.__contactSponsorIntervalId = null;
    }
  });
</script>

<style>
  header {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-weight: 700;
    padding: 1rem 0;
    gap: 1rem;
  }
  h1 {
    font-size: 1rem;
    font-weight: inherit;
    line-height: 0;
    margin: 0;
  }
  .site-logo {
    display: block;
    width: min(160px, 35vw);
    height: auto;
  }
  nav {
    width: 100%;
  }
  ul {
    display: flex;
    list-style: none;
    gap: 1.25rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    margin: 0;
    padding: 0;
  }
  .contact-label {
    display: inline-block;
    min-width: 7ch;
    text-align: center;
    transition: opacity 0.35s ease;
  }
  .contact-label.is-fading {
    opacity: 0.35;
  }
  @media screen and (min-width: 50em) {
    header {
      padding-top: 0.8rem;
    }
  }
</style>
